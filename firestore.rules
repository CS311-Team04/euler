rules_version = '2';
service cloud.firestore {
    match /databases/{db}/documents {

        function isSignedIn() { return request.auth != null; }
        function isRegistered() {
            return exists(/databases/$(db)/documents/users/$(request.auth.uid));
        }
        function isEnabled() {
            return get(/databases/$(db)/documents/users/$(request.auth.uid)).data.enabled == true;
        }

        // Chaque user gère son propre profil
        match /users/{uid} {
            allow read, write: if isSignedIn() && request.auth.uid == uid;
        }

        // Accès au reste de l'app UNIQUEMENT si inscrit (+ activé si tu veux approuver)
        match /{document=**} {
            // simple : inscrit
            // allow read, write: if isSignedIn() && isRegistered();

            // approuvé : inscrit + enabled=true
            allow read, write: if isSignedIn() && isRegistered() && isEnabled();
        }
    }
}
